VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_AUTH_REDIRECT_URL=https://pixelorcode-ops.vercel.app

# Server-side only. Used by Vercel campaign/OAuth functions and local import scripts.
# Never expose this with a VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Inngest Vercel integration supplies these in production.
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Server-side Google OAuth for durable/offline Gmail sending.
GOOGLE_CLIENT_ID=your-google-web-client-id
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
GOOGLE_REDIRECT_URI=https://pixelorcode-ops.vercel.app/api/google-oauth

# Generate with: openssl rand -base64 32
EMAIL_TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=at-least-32-random-characters
APP_ORIGIN=https://pixelorcode-ops.vercel.app

# Bulk Fire: default Hostinger address shown in the "Send from" SMTP option.
VITE_HOSTINGER_EMAIL=ankit@riaanitconsultants.com

# Hostinger SMTP — server-side only (used by api/send-email.js). Set these in
# Vercel → Project → Settings → Environment Variables. NEVER prefix with VITE_
# (that would leak the password into the browser bundle).
HOSTINGER_SMTP_USER=ankit@riaanitconsultants.com
HOSTINGER_SMTP_PASS=your-hostinger-mailbox-password
# Display name placed in the MIME From header for SMTP campaigns.
HOSTINGER_FROM_NAME=Riaan IT Consultants
CAMPAIGN_NOTIFICATION_EMAIL=vanshkalra1379@gmail.com
# Optional overrides:
# HOSTINGER_SMTP_HOST=smtp.hostinger.com
# HOSTINGER_SMTP_PORT=465
# HOSTINGER_SMTP_SECURE=true

# Saving a copy to the Sent folder uses IMAP with the SAME user/pass as SMTP.
# Defaults below work for Hostinger, so you usually don't need to set these.
# HOSTINGER_IMAP_HOST=imap.hostinger.com
# HOSTINGER_IMAP_PORT=993
# HOSTINGER_SAVE_TO_SENT=false   # set to disable saving Sent copies
