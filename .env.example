VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_AUTH_REDIRECT_URL=https://pixelorcode-ops.vercel.app

# Local scripts only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Bulk Fire: default Hostinger address shown in the "Send from" SMTP option.
VITE_HOSTINGER_EMAIL=ankit@riaanitconsultants.com

# Hostinger SMTP — server-side only (used by api/send-email.js). Set these in
# Vercel → Project → Settings → Environment Variables. NEVER prefix with VITE_
# (that would leak the password into the browser bundle).
HOSTINGER_SMTP_USER=ankit@riaanitconsultants.com
HOSTINGER_SMTP_PASS=your-hostinger-mailbox-password
# Optional overrides:
# HOSTINGER_SMTP_HOST=smtp.hostinger.com
# HOSTINGER_SMTP_PORT=465
